#: enfold-ticker.php
msgid "enfold-ticker requires the Enfold theme to be installed and active. The Ticker element will not appear in the layout builder without it."
msgstr "enfold-ticker setzt voraus, dass das Enfold-Theme installiert und aktiv ist. Ohne es erscheint das Ticker-Element nicht im Layout-Builder."

#: shortcodes/avia-ticker.php
msgid "Ticker"
msgstr "Ticker"

#: shortcodes/avia-ticker.php
msgid "Add a scrolling news ticker"
msgstr "Einen laufenden News-Ticker hinzufügen"

#: shortcodes/avia-ticker.php
msgid "Content"
msgstr "Inhalt"

#: shortcodes/avia-ticker.php
msgid "Ticker Content"
msgstr "Ticker-Text"

#: shortcodes/avia-ticker.php
msgid "Enter the text to display in the ticker."
msgstr "Geben Sie den Text ein, der im Ticker angezeigt werden soll."

#: shortcodes/avia-ticker.php
msgid "Your ticker text goes here"
msgstr "Hier steht Ihr Ticker-Text"

#: shortcodes/avia-ticker.php
msgid "Styling"
msgstr "Darstellung"

#: shortcodes/avia-ticker.php
msgid "Font Size"
msgstr "Schriftgröße"

#: shortcodes/avia-ticker.php
msgid "Ticker font size, e.g. 16px or 1rem."
msgstr "Schriftgröße des Tickers, z. B. 16px oder 1rem."

#: shortcodes/avia-ticker.php
msgid "Scroll duration"
msgstr "Scroll-Dauer"

#: shortcodes/avia-ticker.php
msgid "Duration in seconds for one full loop (5-300). Lower is faster, higher is slower."
msgstr "Dauer in Sekunden für einen kompletten Durchlauf (5–300). Niedriger schneller, höher langsamer."

#: shortcodes/avia-ticker.php
msgid "Scroll Direction"
msgstr "Scroll-Richtung"

#: shortcodes/avia-ticker.php
msgid "Direction the ticker text scrolls."
msgstr "Richtung, in der der Ticker-Text scrollt."

#: shortcodes/avia-ticker.php
msgid "Right to Left (default)"
msgstr "Rechts nach links (Standard)"

#: shortcodes/avia-ticker.php
msgid "Left to Right"
msgstr "Links nach rechts"
